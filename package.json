{
  "name": "iservice",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@rescripts/cli": "^0.0.13",
    "@rescripts/rescript-env": "^0.0.11",
    "concurrently": "^4.1.0",
    "electron": "^6.0.12",
    "electron-builder": "^21.2.0",
    "wait-on": "^3.2.0"
  },
  "build": {
    "appId": "iservice.app",
    "productName": "iservice",
    "copyright": "Copyright © 2019 begaak",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "electron-is-dev": "^1.1.0",
    "moment": "^2.24.0",
    "portscanner": "^2.2.0",
    "pouchdb-adapter-http": "^7.1.1",
    "pouchdb-adapter-idb": "^7.1.1",
    "pouchdb-server": "^4.2.0",
    "react": "^16.10.2",
    "react-dom": "^16.10.2",
    "react-scripts": "3.2.0",
    "react-toastify": "^5.4.0",
    "rxdb": "^8.7.0",
    "rxjs": "^6.5.3",
    "serve": "^11.2.0",
    "typescript": "^3.6.4",
    "yarn": "^1.19.1"
  },
  "homepage": "./",
  "main": "public/electron.js",
  "scripts": {
    "electron-dev": "concurrently \"pouchdb-server -d ./db\" \"yarn start\" \"wait-on http://localhost:3000 && electron .\"",
    "start": "react-scripts start",
    "build": "react-scripts build && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "electron-builder install-app-deps",
    "preelectron-pack": "yarn build",
    "electron-pack": "build -mw",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "electronWebpack": {
    "commonSourceDirectory": "common",
    "main": {
      "sourceDirectory": "main"
    },
    "renderer": {
      "sourceDirectory": null
    }
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
